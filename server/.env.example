# Application
NODE_ENV=development
PORT=5000
APP_NAME=Glamour
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=glamour_dev
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your_super_secret_key_for_development_only_min_32_chars
JWT_EXPIRE=3600
JWT_REFRESH_SECRET=another_super_secret_key_for_refresh_token_min_32_chars
JWT_REFRESH_EXPIRE=604800

# Email (SendGrid)
SMTP_HOST=smtp.example.com
SMTP_USER=user
SMTP_PASSWORD=password
SMTP_FROM_EMAIL=noreply@glamour.io

# Google Gemini AI (Required for all AI-powered features)
GEMINI_API_KEY=your_gemini_api_key_here
